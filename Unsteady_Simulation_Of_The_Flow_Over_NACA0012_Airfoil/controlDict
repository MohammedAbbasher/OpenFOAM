FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

//From the tutorial on the internet: 
application     icoFoam;
//application     foamRun;

//The solver is not decided in the case of the tutorial in the internet, why?
solver          icoFoam;
//what is the differennce between latest time and startTime
startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         100;

deltaT          0.001;

writeControl    timeStep;

writeInterval   50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;
//I think I need to take care of this runtimemodifiable

runTimeModifiable true;

   functions
{
    forces
    {
        type            forces;
        functionObjectLibs ("libforces.so");
        writeControl   timeStep;
        writeInterval  1; // Adjust as needed
        patches         ("lowerwall" "upperwall"); // Replace with the name of your patch(es)
        rho             rhoInf;     // For incompressible, set rhoInf
        rhoInf          1.225;      // Set the air density
        CofR            (0 0 0);    // Center of rotation
    }

    forceCoeffs
    {
    type            forceCoeffs;
    functionObjectLibs ("libforces.so");
    outputControl   timeStep;
    outputInterval  1;
    patches         ("lowerwall" "upperwall"); // Match your patch names
    rho             rhoInf;
    rhoInf          1.225; // Free stream density
    liftDir         (0 1 0); // Lift direction (Y-axis for 2D flows)
    dragDir         (1 0 0); // Drag direction (X-axis for 2D flows)
    pitchAxis       (0 0 1); // Axis for moment calculation (Z-axis for 2D flows)
    CofR            (0 0 0); // Center of rotation
    magUInf         1; // Free stream velocity
    lRef            1; // Reference length
    Aref            1; // Reference area
    }
}
