//This part is from the internet tutorial
solvers
{
    p
    {
        solver GAMG;
        tolerance 1e-04;
        relTol 0.01;
        smoother GaussSeidel;
        nPreSweeps 0;
        nPostSweeps 2;
        cacheAgglomeration on;
        agglomerator faceAreaPair;
        nCellsInCoarsestLevel 1000;
        mergeLevels 1;
    }
    U
    //I changed the tolerance here from -05 to -06
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0;
    }
    pFinal
    {
        solver GAMG;
        tolerance 1e-06;
        relTol 0.0;
        smoother GaussSeidel;
        nPreSweeps 0;
        nPostSweeps 2;
        cacheAgglomeration on;
        agglomerator faceAreaPair;
        nCellsInCoarsestLevel 1000;
        mergeLevels 1;
    }
    //Need to understand why he added this part regardless of the fact that we are talking about laminar flow
    /*"(U|k|epsilon|omega|R|nuTilda)"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-05;
        relTol          0;
    }*/

}



