{
    nCorrectors       3;  // Number of corrector loops for pressure-velocity coupling
    nNonOrthogonalCorrectors 1;  // Non-orthogonal correctors
    momentumPredictor yes;  // Use the momentum predictor step
    pRefPoint       (0 0 0);  // Coordinate of the reference point
